{
  "name": "Seti",
  "type": "dark",
  "colors": {
    "editor.background": "#151718",
    "editor.foreground": "#CFD2D1",
    "editor.lineHighlightBackground": "#1d1f20",
    "editor.selectionBackground": "#253340",
    "editorCursor.foreground": "#9fca56",
    "editorWhitespace.foreground": "#2a2f3a"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#41535b",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated",
        "string.regexp",
        "meta.import string",
        "string.quoted.include"
      ],
      "settings": {
        "foreground": "#55b5db"
      }
    },
    {
      "name": "String escape",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#9fca56"
      }
    },
    {
      "name": "Number / boolean / null — constant",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.none"
      ],
      "settings": {
        "foreground": "#cd3f45"
      }
    },
    {
      "name": "Keyword — control flow, import, class, def, function, let, const, var",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.export",
        "keyword.other",
        "keyword.declaration",
        "storage.type",
        "storage.type.js",
        "storage.type.ts",
        "storage.type.function",
        "storage.type.class",
        "storage.type.enum",
        "storage.modifier",
        "variable.language.this",
        "variable.language.super",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#e6cd69"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.assignment",
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.instanceof",
        "keyword.operator.in",
        "keyword.operator.spread",
        "keyword.operator.rest"
      ],
      "settings": {
        "foreground": "#9fca56"
      }
    },
    {
      "name": "Attribute / parameter / variable3",
      "scope": [
        "variable.parameter",
        "entity.other.attribute-name",
        "meta.attribute"
      ],
      "settings": {
        "foreground": "#9fca56"
      }
    },
    {
      "name": "Definition — function / method name, entity name",
      "scope": [
        "entity.name.function",
        "entity.name.method",
        "meta.function-call entity.name.function",
        "support.function",
        "support.function.builtin",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#55b5db"
      }
    },
    {
      "name": "Meta — import path, module reference",
      "scope": [
        "meta.import",
        "meta.import-export",
        "entity.name.module",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#55b5db"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#55b5db"
      }
    },
    {
      "name": "Variable — general identifier",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.constant",
        "variable.other.local"
      ],
      "settings": {
        "foreground": "#55b5db"
      }
    },
    {
      "name": "Property / variable2 — object member, type annotation",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "meta.object.member",
        "support.type.property-name",
        "entity.name.class",
        "entity.name.type",
        "entity.name.type.class",
        "entity.name.type.interface",
        "entity.name.type.alias",
        "entity.name.type.enum",
        "entity.other.inherited-class",
        "support.class",
        "support.type",
        "meta.type.annotation entity.name.type",
        "meta.return.type entity.name.type"
      ],
      "settings": {
        "foreground": "#a074c4"
      }
    },
    {
      "name": "Decorator / annotation",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "support.token.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#e6cd69"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.string",
        "meta.brace",
        "meta.brackets"
      ],
      "settings": {
        "foreground": "#CFD2D1"
      }
    },
    {
      "name": "Tag attribute",
      "scope": ["entity.other.attribute-name.html", "entity.other.attribute-name.jsx"],
      "settings": {
        "foreground": "#9fca56"
      }
    },
    {
      "name": "YAML key",
      "scope": [
        "entity.name.tag.yaml",
        "string.unquoted.plain.out.yaml",
        "punctuation.definition.key.yaml"
      ],
      "settings": {
        "foreground": "#9fca56"
      }
    },
    {
      "name": "YAML string value",
      "scope": [
        "string.unquoted.plain.in.yaml",
        "string.quoted.double.yaml",
        "string.quoted.single.yaml"
      ],
      "settings": {
        "foreground": "#55b5db"
      }
    },
    {
      "name": "YAML anchor / alias",
      "scope": ["entity.name.type.anchor.yaml", "variable.other.alias.yaml"],
      "settings": {
        "foreground": "#cd3f45"
      }
    },
    {
      "name": "Bash built-in / command",
      "scope": [
        "support.function.builtin.shell",
        "entity.name.command",
        "keyword.other.shell-script"
      ],
      "settings": {
        "foreground": "#9fca56"
      }
    },
    {
      "name": "Python built-in / self",
      "scope": [
        "support.function.builtin.python",
        "support.type.python",
        "variable.language.special.self.python"
      ],
      "settings": {
        "foreground": "#55b5db"
      }
    },
    {
      "name": "Invalid / deprecated",
      "scope": ["invalid", "invalid.deprecated"],
      "settings": {
        "foreground": "#cd3f45",
        "fontStyle": "underline"
      }
    }
  ]
}
